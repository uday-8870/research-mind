# ============================================
# ResearchMind — Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys

# --- LLM Provider (choose one) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Which model to use as the backbone
LLM_PROVIDER=openai          # "openai" or "anthropic"
LLM_MODEL=gpt-4o             # or "claude-sonnet-4-20250514"

# --- Web Search ---
TAVILY_API_KEY=tvly-...

# --- Vector Store ---
CHROMA_PERSIST_DIR=./data/chroma

# --- Observability (optional but recommended) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=research-mind

# --- App Config ---
MAX_SEARCH_RESULTS=8
MAX_CHUNKS_PER_DOC=20
RESEARCH_DEPTH=deep          # "quick" | "standard" | "deep"
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Eval ---
EVAL_JUDGE_MODEL=gpt-4o-mini
RUN_EVAL=true
